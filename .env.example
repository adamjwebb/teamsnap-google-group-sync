# ─── TeamSnap ─────────────────────────────────────────────────────────────────
# Preferred: OAuth client credentials + refresh token (works for automation)
# Run `python get_token.py --client-id ... --client-secret ...` to get these.
TEAMSNAP_CLIENT_ID=your-teamsnap-client-id
TEAMSNAP_CLIENT_SECRET=your-teamsnap-client-secret
TEAMSNAP_REFRESH_TOKEN=your-teamsnap-refresh-token

# Alternative: static access token (simpler but may expire)
# TEAMSNAP_TOKEN=your-teamsnap-access-token

# Your TeamSnap organization ID (visible in the org URL, e.g. go.teamsnap.com/123456/...)
TEAMSNAP_ORG_ID=123456

# ─── Google ───────────────────────────────────────────────────────────────────
# Email address of the Google Group to sync
GOOGLE_GROUP_EMAIL=myteam@example.com

# A Google Workspace admin account used for impersonation (domain-wide delegation)
GOOGLE_ADMIN_EMAIL=admin@example.com

# Path to the Google service account JSON key file
# See README for how to create this key and grant the required permissions.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
