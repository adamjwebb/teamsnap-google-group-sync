# ─── TeamSnap ─────────────────────────────────────────────────────────────────
# Personal access token from https://app.teamsnap.com/api/v3#authentication
TEAMSNAP_TOKEN=your-teamsnap-oauth-token

# Your TeamSnap organization ID (visible in the org URL or API response)
TEAMSNAP_ORG_ID=123456

# ─── Google ───────────────────────────────────────────────────────────────────
# Email address of the Google Group to sync
GOOGLE_GROUP_EMAIL=myteam@example.com

# A Google Workspace admin account used for impersonation (domain-wide delegation)
GOOGLE_ADMIN_EMAIL=admin@example.com

# Path to the Google service account JSON key file
# See README for how to create this key and grant the required permissions.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
